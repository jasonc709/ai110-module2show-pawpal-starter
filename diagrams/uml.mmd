classDiagram
    %% PawPal+ class diagram — based on brainstormed design in reflection.md
    %% Core classes: Owner, Pet, Task, Scheduler (+ Frequency enum)
    %% Conflict pairs returned by detect_conflicts() are (Task, Task) tuples.

    class Frequency {
        <<enumeration>>
        ONCE
        DAILY
        WEEKLY
    }

    class Owner {
        +str name
        +list~Pet~ pets
        +add_pet(pet: Pet) None
        +remove_pet(pet_id: int) None
        +list_pets() list~Pet~
    }

    class Pet {
        +int id
        +str name
        +str species
        +int age
        +list~Task~ tasks
        +add_task(task: Task) None
        +remove_task(task_id: int) None
        +list_tasks() list~Task~
    }

    class Task {
        +int id
        +str description
        +time scheduled_time
        +int duration_minutes
        +Frequency frequency
        +str priority
        +str pet_name
        +bool completed
        +mark_done() None
        +is_high_priority() bool
    }

    class Scheduler {
        +Owner owner
        +collect_tasks() list~Task~
        +build_schedule(day: date) list~Task~
        +sort_by_time() list~Task~
        +view_today() list~Task~
        +detect_conflicts() list~Pair~
        +explain_plan() str
    }

    Owner "1" --> "*" Pet : owns
    Pet "1" --> "*" Task : has
    Task ..> Frequency : uses
    Scheduler --> Owner : plans for
