classDiagram
    %% PawPal+ class diagram — based on brainstormed design in reflection.md
    %% Four core classes: Owner, Pet, Task, Scheduler

    class Owner {
        +str name
        +list~Pet~ pets
        +add_pet(pet: Pet) None
        +remove_pet(pet: Pet) None
        +list_pets() list~Pet~
    }

    class Pet {
        +str name
        +str species
        +int age
        +list~Task~ tasks
        +add_task(task: Task) None
        +remove_task(task: Task) None
        +list_tasks() list~Task~
    }

    class Task {
        +str description
        +time scheduled_time
        +int duration_minutes
        +str frequency
        +str priority
        +bool completed
        +mark_done() None
        +is_high_priority() bool
    }

    class Scheduler {
        +list~Task~ tasks
        +add_task(task: Task) None
        +build_schedule(day: date) list~Task~
        +sort_by_time() list~Task~
        +view_today() list~Task~
        +detect_conflicts() list~Task~
        +explain_plan() str
    }

    Owner "1" --> "*" Pet : owns
    Pet "1" --> "*" Task : has
    Scheduler "1" --> "*" Task : organizes
